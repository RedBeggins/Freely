{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Freely",
  "version": "1.0.0",
  "identifier": "com.srikanthnani.freely",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
"app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Freely - AI Assistant",
        "width": 600,
        "height": 56,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "visible": true,
        "center": false,
        "contentProtected": true,
        "focus": false,
        "acceptFirstMouse": true,
        "shadow": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "shortDescription": "Privacy-first AI desktop overlay for meetings and everyday work.",
    "longDescription": "Freely is a fast, private AI assistant that lives as a discreet desktop overlay — meetings, interviews, coding, and daily tasks without drawing attention.",
    "category": "Productivity",
    "license": "GPL-3.0",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["info.plist", "freely.desktop"],
    "macOS": { "minimumSystemVersion": "10.13" }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:freely.db"]
    },
    "updater": {
      "endpoints": ["https://freely.com/api/update"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2RDJBNUFFM0ZCREEyQjEKUldTeG9yMC9ycVhTWmlBRkovV2N5L3RudDhTTHFzM3QxSkF0R0doRGtvSUJKWktpdGp4cWRhcmcK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
